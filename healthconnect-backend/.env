# Google OAuth 2.0 Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here

# SMTP configuration - BREVO SMTP RELAY
SMTP_HOST=smtp-relay.brevo.com
SMTP_SERVER=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_smtp_user_here
SMTP_PASS=your_brevo_smtp_password_here
SENDER_EMAIL=your_sender_email@example.com
FROM_EMAIL=your_from_email@example.com
FROM_NAME=MedTech

# Optional: Set to 1 to always show OTP in response (useful for testing)
OTP_DEBUG=0

# Frontend URL for password reset links
FRONTEND_URL=https://medtech-4rjc.onrender.com

# Brevo SMTP relay settings - CRITICAL:
# - SMTP_USER and SMTP_PASS must be Brevo-specific credentials
# - FROM_EMAIL can be any verified email address in Brevo
# - These are used for outbound email delivery via Brevo SMTP relay
# Backend URL baked into frontend at build-time.
# For internal Docker networking, backend service DNS is 'backend'.
VITE_API_URL=http://backend:5000

# Public frontend URL that backend uses for generated links (reset password, etc.).
FRONTEND_URL=http://localhost:3000

# Optional gunicorn tuning (can be passed through backend env file if desired)
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120